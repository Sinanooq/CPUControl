<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <!-- ── TETHERING ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <TextView android:text="İNTERNET PAYLAŞIMI" android:textSize="9sp"
                    android:textColor="@color/accent_green" android:textStyle="bold"
                    android:letterSpacing="0.15" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="WiFi Hotspot Paylaşımı" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Root ile hotspot aç, bağlanan cihazlar VPN olmadan internet alır"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTethering"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="14dp"
                    android:layout_marginTop="4dp"/>

                <!-- SSID -->
                <TextView android:text="Ağ Adı (SSID)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etShareSsid"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="CPUControl"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@color/bg_elevated"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:inputType="text"
                    android:layout_marginBottom="10dp"/>

                <!-- Şifre -->
                <TextView android:text="Şifre (min 8 karakter)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etSharePass"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="cpucontrol123"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@color/bg_elevated"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:inputType="textPassword"
                    android:layout_marginBottom="14dp"/>

                <TextView android:id="@+id/tvTetheringInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="4dp"/>

                <TextView android:id="@+id/tvTetheringStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── TCP ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <TextView android:text="TCP OPTİMİZASYONU" android:textSize="9sp"
                    android:textColor="@color/accent_cyan" android:textStyle="bold"
                    android:letterSpacing="0.15" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="18dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="BBR Congestion Control" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTcpCongestion" android:text="Mevcut: —"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTcp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Düşük Gecikme Modu" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="tcp_low_latency + hızlı açılış"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchLowLatency"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── WİFİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <TextView android:text="WİFİ" android:textSize="9sp"
                    android:textColor="@color/accent_purple" android:textStyle="bold"
                    android:letterSpacing="0.15" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="WiFi Güç Tasarrufu Kapat" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Daha düşük ping için güç tasarrufunu kapat"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchWifiPowerSave"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── YENİLEME HIZI ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <TextView android:text="YENİLEME HIZI" android:textSize="9sp"
                    android:textColor="@color/accent_yellow" android:textStyle="bold"
                    android:letterSpacing="0.15" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView android:text="Hedef" android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvRefreshRate" android:text="90 Hz"
                        android:textSize="26sp" android:textStyle="bold"
                        android:textColor="@color/accent_yellow"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="end"/>
                </LinearLayout>

                <SeekBar android:id="@+id/seekRefreshRate"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:max="2" android:progress="1"
                    android:progressTint="@color/accent_yellow" android:thumbTint="@color/accent_yellow"
                    android:layout_marginBottom="18dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyRefresh"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:text="Yenileme Hızını Uygula"
                    android:textColor="@android:color/black"
                    android:backgroundTint="@color/accent_yellow"
                    app:cornerRadius="16dp"/>

                <TextView android:id="@+id/tvRefreshStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginTop="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── TTL FIX ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <TextView android:text="TTL FIX" android:textSize="9sp"
                    android:textColor="@color/accent_orange" android:textStyle="bold"
                    android:letterSpacing="0.15" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:layout_marginBottom="4dp"/>

                <TextView android:text="Hotspot tespitini engeller, tüm cihazlar aynı TTL ile görünür"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="TTL Sabitle" android:textSize="15sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTtlCurrent" android:text="Mevcut TTL: —"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"/>
                    </LinearLayout>

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTtl"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <!-- TTL değer seçimi -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTtl64"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="64"
                        android:textSize="13sp" android:textColor="@color/accent_orange"
                        android:backgroundTint="@color/accent_orange_dim"
                        app:cornerRadius="12dp" android:layout_marginEnd="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTtl128"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="128"
                        android:textSize="13sp" android:textColor="@color/accent_orange"
                        android:backgroundTint="@color/accent_orange_dim"
                        app:cornerRadius="12dp" android:layout_marginEnd="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnTtl255"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="255"
                        android:textSize="13sp" android:textColor="@color/accent_orange"
                        android:backgroundTint="@color/accent_orange_dim"
                        app:cornerRadius="12dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvTtlStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center" android:textSize="12sp"
                    android:textColor="@color/text_secondary"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── DNS DEĞİŞTİRİCİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="22dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="6dp">

                    <TextView android:text="DNS DEĞİŞTİRİCİ" android:textSize="9sp"
                        android:textColor="@color/accent_cyan" android:textStyle="bold"
                        android:letterSpacing="0.15" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"/>

                    <TextView android:id="@+id/tvCurrentDns" android:text="Mevcut DNS: —"
                        android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <TextView android:text="Hızlı DNS seçimi veya özel DNS girin"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="18dp"/>

                <!-- Hızlı DNS butonları -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDnsCloudflare"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="Cloudflare"
                        android:textSize="12sp" android:textColor="@color/accent_cyan"
                        android:backgroundTint="@color/accent_cyan_dim"
                        app:cornerRadius="12dp" android:layout_marginEnd="6dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDnsGoogle"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="Google"
                        android:textSize="12sp" android:textColor="@color/accent_green"
                        android:backgroundTint="@color/accent_green_dim"
                        app:cornerRadius="12dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="16dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDnsAdguard"
                        android:layout_width="0dp" android:layout_height="44dp"
                        android:layout_weight="1" android:text="AdGuard"
                        android:textSize="12sp" android:textColor="@color/accent_purple"
                        android:backgroundTint="@color/accent_purple_dim"
                        app:cornerRadius="12dp" android:layout_marginEnd="6dp"/>

                    <View android:layout_width="0dp" android:layout_height="0dp"
                        android:layout_weight="1"/>
                </LinearLayout>

                <!-- Özel DNS -->
                <EditText android:id="@+id/etCustomDns"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:hint="Özel DNS (örn: 1.1.1.1)"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:background="@color/bg_elevated"
                    android:paddingStart="16dp" android:paddingEnd="16dp"
                    android:inputType="text"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnDnsCustom"
                    android:layout_width="match_parent" android:layout_height="54dp"
                    android:text="Özel DNS Uygula"
                    android:textColor="@android:color/black"
                    android:backgroundTint="@color/accent_cyan"
                    app:cornerRadius="16dp"/>

                <TextView android:id="@+id/tvDnsStatus"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center" android:textSize="12sp"
                    android:textColor="@color/text_secondary" android:layout_marginTop="10dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
