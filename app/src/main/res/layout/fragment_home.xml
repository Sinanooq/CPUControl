<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <!-- ── HERO KART ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <!-- Başlık + sıcaklık -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="22dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Dimensity 8300 Ultra"
                            android:textSize="19sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="4+3+1  ·  TSMC 4nm  ·  ARMv9"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="3dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Sıcaklık badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/accent_orange_dim"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:id="@+id/tvHomeTemp"
                            android:text="—°C"
                            android:textSize="24sp"
                            android:textColor="@color/accent_orange"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="SICAKLIK"
                            android:textSize="8sp"
                            android:textColor="@color/accent_orange"
                            android:letterSpacing="0.15"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Çekirdek grupları -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_green_dim"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">

                        <TextView android:text="LITTLE" android:textSize="8sp"
                            android:textColor="@color/accent_green" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvLittleFreq" android:text="—"
                            android:textSize="20sp" android:textColor="@color/accent_green"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                        <TextView android:text="cpu0–3  ·  A510" android:textSize="9sp"
                            android:textColor="@color/text_secondary" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_cyan_dim"
                        android:padding="14dp"
                        android:layout_marginEnd="6dp">

                        <TextView android:text="BIG" android:textSize="8sp"
                            android:textColor="@color/accent_cyan" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvBigFreq" android:text="—"
                            android:textSize="20sp" android:textColor="@color/accent_cyan"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                        <TextView android:text="cpu4–6  ·  A715" android:textSize="9sp"
                            android:textColor="@color/text_secondary" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_purple_dim"
                        android:padding="14dp">

                        <TextView android:text="PRIME" android:textSize="8sp"
                            android:textColor="@color/accent_purple" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvPrimeFreq" android:text="—"
                            android:textSize="20sp" android:textColor="@color/accent_purple"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="4dp"/>
                        <TextView android:text="cpu7  ·  Prime" android:textSize="9sp"
                            android:textColor="@color/text_secondary" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PİL + GPU ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="24dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:text="PİL" android:textSize="8sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvBattery" android:text="—%"
                        android:textSize="38sp" android:textColor="@color/accent_green"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"/>

                    <TextView android:id="@+id/tvCharging" android:text="—"
                        android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="24dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView android:text="GPU" android:textSize="8sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvGpuFreq" android:text="—"
                        android:textSize="26sp" android:textColor="@color/accent_yellow"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="4dp"/>

                    <TextView android:text="Mali-G615 MC6" android:textSize="11sp"
                        android:textColor="@color/text_secondary" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── AKTİF PROFİL ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/accent_cyan_dim"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView android:text="AKTİF PROFİL" android:textSize="8sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvActiveProfile" android:text="—"
                        android:textSize="24sp" android:textColor="@color/accent_cyan"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="2dp"/>
                </LinearLayout>

                <TextView android:id="@+id/tvAutoProfile" android:text="Manuel"
                    android:textSize="11sp" android:textColor="@color/accent_cyan"
                    android:background="@color/accent_cyan_dim"
                    android:paddingStart="12dp" android:paddingEnd="12dp"
                    android:paddingTop="6dp" android:paddingBottom="6dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── ÇEKİRDEKLER ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="ÇEKİRDEKLER" android:textSize="8sp"
                    android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                    android:layout_marginBottom="14dp" android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:id="@+id/llCoreStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── FREKANS GRAFİĞİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:text="CANLI FREKANS"
                        android:textSize="8sp"
                        android:textColor="@color/text_secondary"
                        android:letterSpacing="0.2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                    <TextView
                        android:id="@+id/tvChartStatus"
                        android:text="● CANLI"
                        android:textSize="9sp"
                        android:textColor="@color/accent_green"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <com.cpucontrol.FreqChartView
                    android:id="@+id/freqChart"
                    android:layout_width="match_parent"
                    android:layout_height="140dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── YENİLE ── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRefresh"
            android:text="Yenile"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            app:cornerRadius="16dp"
            android:backgroundTint="@color/bg_card"
            android:textColor="@color/accent_cyan"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"/>

    </LinearLayout>
</ScrollView>
