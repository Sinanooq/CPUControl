<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="32dp">

        <!-- ── KİMLİK KARTI ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent_cyan_dim"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <TextView
                    android:text="İşlemci Kontrolü"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:textColor="@color/accent_cyan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Dimensity 8300 Ultra · Root Sistem Yöneticisi"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="6dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <View
                    android:layout_width="60dp"
                    android:layout_height="2dp"
                    android:background="@color/accent_cyan"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:text="Sinan Aslan tarafından kodlandı"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="github.com/Sinanooq/CPUControl"
                    android:textSize="12sp"
                    android:textColor="@color/accent_purple"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="v1.0  ·  Açık Kaynak  ·  Root Gerektirir"
                    android:textSize="10sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginTop="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CPU / GPU ÖZELLİKLERİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="⚡  CPU / GPU"
                    android:textSize="10sp" android:textColor="@color/accent_cyan"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="• CPU frekans kontrolü — çekirdek bazlı min/maks ayarı (Little / Big / Prime)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Tüm çekirdekler tek ekrandan toplu kontrol (AllCPU)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• CPU governor seçimi (schedutil, performance, powersave…)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Çekirdek online/offline kontrolü (cpu0 kapatılamaz)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• GPU frekans kontrolü — Mali-G615 MC6 min/maks ayarı"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Gerçek zamanlı CPU frekans grafiği (son 60 saniye, 3 çizgi)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── EKRAN / YENİLEME ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="🖥  EKRAN"
                    android:textSize="10sp" android:textColor="@color/accent_yellow"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="• Yenileme hızı kontrolü — 60 / 90 / 120 Hz"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Otomatik yenileme hızı — senaryoya göre akıllı ayar"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="    🎮 Oyun modu → 120 Hz  ·  ⚡ Şarj → 120 Hz"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="4dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="    📱 Normal → 90 Hz  ·  🔋 Düşük pil → 60 Hz"
                    android:textSize="11sp" android:textColor="@color/text_hint"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Gerçek zamanlı overlay — CPU/GPU/sıcaklık ekran üstü gösterge"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PROFİL / OYUN ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="🎮  PROFİL / OYUN"
                    android:textSize="10sp" android:textColor="@color/accent_green"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="• 5 hazır profil: Dengeli / Performans / Oyun / Pil Tasarrufu / Gece"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Otomatik profil servisi — pil seviyesine göre geçiş"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Oyun algılama — ön plan uygulama izleme, otomatik oyun profili"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Uygulama bazlı profil — her uygulamaya özel profil atama"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Önyükleme uygulaması — cihaz açılışında profil otomatik yüklenir"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PİL / SES / AĞ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="🔋  PİL / SES / AĞ"
                    android:textSize="10sp" android:textColor="@color/accent_orange"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="• Şarj limiti — %80 gibi özel eşikte şarjı durdur"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Gece şarj planı — belirli saatte yavaş şarj"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Ses amplifikasyonu — %100–%250 yazılım yükseltme (LoudnessEnhancer)"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Medya / Zil / Alarm ses seviyesi kontrolü"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• TCP optimizasyonu — BBR, düşük gecikme, tampon ayarı"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• WiFi güç tasarrufu kontrolü"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── SİSTEM ARAÇLARI ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="🛠  SİSTEM ARAÇLARI"
                    android:textSize="10sp" android:textColor="@color/accent_purple"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView android:text="• Doze modu — zorla derin uyku, pil tasarrufu"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Doze istisnaları — WhatsApp, Telegram gibi uygulamalar etkilenmez"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Bloatware yöneticisi — sistem uygulamalarını dondur/aktif et"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• Risk seviyesi göstergesi — Güvenli / Dikkatli / Tehlikeli"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_marginBottom="7dp"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
                <TextView android:text="• 50+ bilinen MIUI/Xiaomi bloatware otomatik işaretli"
                    android:textSize="12sp" android:textColor="@color/text_secondary"
                    android:layout_width="match_parent" android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CPU MİMARİSİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="CPU MİMARİSİ"
                    android:textSize="10sp" android:textColor="@color/accent_purple"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@color/accent_green" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="cpu0 – cpu3  ·  Küçük Çekirdekler"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Cortex-A510  ·  maks 2.2 GHz  ·  Verimlilik"
                            android:textSize="11sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <View android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@color/accent_cyan" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="cpu4 – cpu6  ·  Büyük Çekirdekler"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Cortex-A715  ·  maks 3.2 GHz  ·  Performans"
                            android:textSize="11sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center_vertical">
                    <View android:layout_width="10dp" android:layout_height="10dp"
                        android:background="@color/accent_purple" android:layout_marginEnd="12dp"/>
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="cpu7  ·  Prime Çekirdek"
                            android:textSize="13sp" android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Cortex-A715  ·  maks 3.35 GHz  ·  Zirve"
                            android:textSize="11sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── NASIL ÇALIŞIR ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView android:text="NASIL ÇALIŞIR"
                    android:textSize="10sp" android:textColor="@color/accent_orange"
                    android:textStyle="bold" android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView
                    android:text="Root erişimi ile doğrudan Linux çekirdeğinin sysfs arayüzüne yazar. CPU frekansları /sys/devices/system/cpu/ altındaki scaling_min/max_freq dosyaları üzerinden, GPU frekansları Mali devfreq arayüzü ile kontrol edilir.\n\nOyun algılama servisi arka planda çalışarak ön plan uygulamayı izler. Uygulama bazlı profil sistemi, her uygulama için ayrı profil tanımlamaya olanak tanır. Doze modu dumpsys deviceidle ile yönetilir. Bloatware yöneticisi pm disable-user komutu ile uygulamaları siler değil, dondurur — geri alınabilir."
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── UYARI ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/accent_orange_dim"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent_orange"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:text="⚠  UYARI"
                    android:textSize="12sp" android:textStyle="bold"
                    android:textColor="@color/accent_orange"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                <TextView
                    android:text="Bu uygulama root erişimi gerektirir. Yanlış frekans ayarları cihazın kararsız çalışmasına neden olabilir. Bloatware dondurma işlemleri geri alınabilir olsa da kritik sistem uygulamalarına dikkat edin. Kullanım sorumluluğu kullanıcıya aittir."
                    android:textSize="12sp"
                    android:textColor="@color/accent_orange"
                    android:lineSpacingMultiplier="1.4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
