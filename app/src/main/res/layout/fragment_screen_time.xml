<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="28dp">

        <!-- İzin gerekli -->
        <LinearLayout
            android:id="@+id/layoutPermission"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/accent_orange_dim"
                app:strokeWidth="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:text="İZİN GEREKLİ" android:textSize="9sp"
                        android:textColor="@color/accent_orange" android:textStyle="bold"
                        android:letterSpacing="0.15" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginBottom="8dp"/>

                    <TextView android:text="Ekran süresi ve uygulama kullanım verilerini görmek için Kullanım Erişimi izni gereklidir."
                        android:textSize="13sp" android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGrantUsage"
                        android:layout_width="match_parent" android:layout_height="48dp"
                        android:text="İzin Ver"
                        android:textColor="@android:color/black"
                        android:backgroundTint="@color/accent_orange"
                        app:cornerRadius="14dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- İçerik -->
        <LinearLayout
            android:id="@+id/layoutContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Başlık + butonlar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/tvPeriodLabel"
                    android:text="DEVAM EDİYOR"
                    android:textSize="11sp"
                    android:textColor="@color/accent_cyan"
                    android:textStyle="bold"
                    android:letterSpacing="0.08"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetCharge"
                    android:text="Sıfırla"
                    android:textSize="11sp"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:textColor="@color/on_primary"
                    android:backgroundTint="@color/accent_cyan"
                    app:cornerRadius="10dp"/>
            </LinearLayout>

            <!-- Ekran Açık / Kapalı / Deep Sleep — Battery Guru stili 3 kutu -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Ekran Açık -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:text="📱" android:textSize="22sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvScreenOnVal" android:text="—"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/accent_green"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Ekran Açık" android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                        <TextView android:id="@+id/tvScreenOnPct" android:text="0%"
                            android:textSize="11sp" android:textColor="@color/accent_green"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

                    <!-- Ekran Kapalı -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:text="🌙" android:textSize="22sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvScreenOffVal" android:text="—"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/accent_purple"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Ekran Kapalı" android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                        <TextView android:id="@+id/tvScreenOffPct" android:text="0%"
                            android:textSize="11sp" android:textColor="@color/accent_purple"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

                    <!-- Deep Sleep -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:text="💤" android:textSize="22sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvDeepSleepVal" android:text="—"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/accent_cyan"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Deep Sleep" android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                        <TextView android:id="@+id/tvDeepSleepPct" android:text="0%"
                            android:textSize="11sp" android:textColor="@color/accent_cyan"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Uptime + Uyanık -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <!-- Çalışma Süresi -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:text="⏱" android:textSize="22sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvUptimeVal" android:text="—"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/accent_yellow"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Çalışma Süresi" android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="match_parent"
                        android:background="@color/divider" android:layout_marginHorizontal="4dp"/>

                    <!-- Uyanık -->
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:gravity="center_horizontal">
                        <TextView android:text="👁" android:textSize="22sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginBottom="4dp"/>
                        <TextView android:id="@+id/tvAwakeVal" android:text="—"
                            android:textSize="18sp" android:textStyle="bold"
                            android:textColor="@color/accent_orange"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="Uyanık (CPU)" android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"/>
                        <TextView android:id="@+id/tvAwakePct" android:text="0%"
                            android:textSize="11sp" android:textColor="@color/accent_orange"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Uygulama kullanımı -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <TextView android:id="@+id/tvAppLabel"
                        android:text="UYGULAMA KULLANIMI"
                        android:textSize="9sp" android:textColor="@color/accent_purple"
                        android:textStyle="bold" android:letterSpacing="0.12"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"/>

                    <LinearLayout
                        android:id="@+id/listAppUsage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </LinearLayout>
</ScrollView>
