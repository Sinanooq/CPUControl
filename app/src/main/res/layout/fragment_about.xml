<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp">

        <!-- Hero kart -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/accent_cyan_dim"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center">

                <!-- İkon placeholder -->
                <ImageView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:src="@drawable/ic_cpu"
                    android:layout_marginBottom="16dp"
                    app:tint="@color/accent_cyan"/>

                <TextView
                    android:text="İşlemci Kontrolü"
                    android:textSize="22sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="v1.0  ·  Dimensity 8300 Ultra"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <View
                    android:layout_width="48dp"
                    android:layout_height="2dp"
                    android:background="@color/accent_cyan"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:text="Sinan Aslan tarafından kodlandı"
                    android:textSize="13sp"
                    android:textColor="@color/accent_cyan"
                    android:gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Uygulama Hakkında -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="UYGULAMA HAKKINDA"
                    android:textSize="8sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="İşlemci Kontrolü, Xiaomi cihazlarda Dimensity 8300 Ultra işlemcisinin CPU ve GPU frekanslarını root yetkisiyle doğrudan çekirdek seviyesinde kontrol etmenizi sağlar.\n\nUygulama, Linux çekirdeğinin sysfs arayüzü üzerinden çalışır. Frekans değerleri /sys/devices/system/cpu/ ve /sys/devices/platform/soc/mali/ yollarına yazılır."
                    android:textSize="13sp"
                    android:textColor="@color/text_primary"
                    android:lineSpacingMultiplier="1.6"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Nasıl Çalışır -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="NASIL ÇALIŞIR"
                    android:textSize="8sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Adım 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:text="1"
                        android:textSize="13sp"
                        android:textColor="@color/accent_cyan"
                        android:textStyle="bold"
                        android:background="@color/accent_cyan_dim"
                        android:gravity="center"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Root Yetkisi"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Uygulama açılışta su komutu ile root yetkisi ister. Magisk, KernelSU veya APatch ile çalışır."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Adım 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:text="2"
                        android:textSize="13sp"
                        android:textColor="@color/accent_green"
                        android:textStyle="bold"
                        android:background="@color/accent_green_dim"
                        android:gravity="center"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Frekans Yazma"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Seçilen min/max frekans değerleri scaling_min_freq ve scaling_max_freq düğümlerine kHz cinsinden yazılır. GPU için Hz cinsinden mali devfreq yoluna yazılır."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Adım 3 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:text="3"
                        android:textSize="13sp"
                        android:textColor="@color/accent_purple"
                        android:textStyle="bold"
                        android:background="@color/accent_purple_dim"
                        android:gravity="center"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Çekirdek Yönetimi"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="cpu0 her zaman açık kalır (sistem zorunluluğu). Diğer çekirdekler /sys/devices/system/cpu/cpuX/online düğümüne 0 veya 1 yazılarak kapatılıp açılabilir."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Adım 4 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:text="4"
                        android:textSize="13sp"
                        android:textColor="@color/accent_yellow"
                        android:textStyle="bold"
                        android:background="@color/accent_yellow_dim"
                        android:gravity="center"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:layout_marginEnd="14dp"
                        android:layout_marginTop="2dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Otomatik Profil"
                            android:textSize="14sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Arka planda çalışan servis 30 saniyede bir pil seviyesini, şarj durumunu ve sıcaklığı kontrol eder. Belirlenen eşiklere göre profil otomatik değiştirilir."
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:lineSpacingMultiplier="1.5"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- İşlemci Mimarisi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="İŞLEMCİ MİMARİSİ"
                    android:textSize="8sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Little -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/accent_green_dim"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="LITTLE  ·  cpu0–3"
                            android:textSize="11sp"
                            android:textColor="@color/accent_green"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Cortex-A510  ·  4 çekirdek"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="169 MHz – 2200 MHz  ·  Verimlilik çekirdekleri"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Big -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/accent_cyan_dim"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="BIG  ·  cpu4–6"
                            android:textSize="11sp"
                            android:textColor="@color/accent_cyan"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Cortex-A715  ·  3 çekirdek"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="300 MHz – 3200 MHz  ·  Performans çekirdekleri"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Prime -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/accent_purple_dim"
                    android:padding="14dp"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="PRIME  ·  cpu7"
                            android:textSize="11sp"
                            android:textColor="@color/accent_purple"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Cortex-A715 Prime  ·  1 çekirdek"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="300 MHz – 3350 MHz  ·  En yüksek performans"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- GPU -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/accent_yellow_dim"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="GPU"
                            android:textSize="11sp"
                            android:textColor="@color/accent_yellow"
                            android:textStyle="bold"
                            android:letterSpacing="0.05"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="Mali-G615 MC6  ·  6 çekirdek"
                            android:textSize="12sp"
                            android:textColor="@color/text_primary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="125 MHz – 1400 MHz  ·  TSMC 4nm"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Uyarılar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/accent_orange_dim"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/accent_orange_dim"
            app:strokeWidth="0dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="UYARILAR"
                    android:textSize="8sp"
                    android:textColor="@color/accent_orange"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="10dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="• Bu uygulama yalnızca Dimensity 8300 Ultra işlemcisi için tasarlanmıştır.\n\n• Yanlış frekans ayarları sistem kararsızlığına veya aşırı ısınmaya yol açabilir.\n\n• Çok düşük maksimum frekans ayarlamak cihazı yavaşlatabilir.\n\n• Ayarlar yeniden başlatmada sıfırlanır; kalıcı olması için Magisk modülü kullanın.\n\n• Geliştirici, yanlış kullanımdan kaynaklanan sorunlardan sorumlu değildir."
                    android:textSize="12sp"
                    android:textColor="@color/accent_orange"
                    android:lineSpacingMultiplier="1.5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Teknik Bilgi -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="24dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:text="TEKNİK BİLGİ"
                    android:textSize="8sp"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2"
                    android:layout_marginBottom="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <!-- Satır -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:text="CPU yolu" android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="/sys/devices/system/cpu/" android:textSize="11sp"
                        android:textColor="@color/accent_cyan" android:fontFamily="monospace"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:text="GPU yolu" android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="soc/13000000.mali/devfreq" android:textSize="11sp"
                        android:textColor="@color/accent_yellow" android:fontFamily="monospace"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:text="Gereksinim" android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="Android 12+  ·  Root" android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="10dp">
                    <TextView android:text="Dil" android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="Kotlin" android:textSize="12sp"
                        android:textColor="@color/text_primary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider" android:layout_marginBottom="10dp"/>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:text="Kaynak Kod" android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="github.com/Sinanooq/CPUControl" android:textSize="11sp"
                        android:textColor="@color/accent_cyan" android:fontFamily="monospace"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
