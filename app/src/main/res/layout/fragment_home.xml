<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="28dp">

        <!-- ── HERO: CPU ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Başlık + sıcaklık -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:text="Dimensity 8300 Ultra"
                            android:textSize="17sp"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="4+3+1  ·  TSMC 4nm  ·  ARMv9"
                            android:textSize="10sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- Sıcaklık badge -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@color/accent_orange_dim"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp">

                        <TextView
                            android:id="@+id/tvHomeTemp"
                            android:text="—°C"
                            android:textSize="22sp"
                            android:textColor="@color/accent_orange"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:text="CPU"
                            android:textSize="8sp"
                            android:textColor="@color/accent_orange"
                            android:letterSpacing="0.15"
                            android:gravity="center"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Çekirdek grupları -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_green_dim"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp">

                        <TextView android:text="LITTLE" android:textSize="7sp"
                            android:textColor="@color/accent_green" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvLittleFreq" android:text="—"
                            android:textSize="18sp" android:textColor="@color/accent_green"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"/>
                        <TextView android:id="@+id/tvLittleGov" android:text="—"
                            android:textSize="9sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                        <TextView android:text="cpu0–3  ·  A510" android:textSize="8sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_cyan_dim"
                        android:padding="12dp"
                        android:layout_marginEnd="5dp">

                        <TextView android:text="BIG" android:textSize="7sp"
                            android:textColor="@color/accent_cyan" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvBigFreq" android:text="—"
                            android:textSize="18sp" android:textColor="@color/accent_cyan"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"/>
                        <TextView android:id="@+id/tvBigGov" android:text="—"
                            android:textSize="9sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                        <TextView android:text="cpu4–6  ·  A715" android:textSize="8sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@color/accent_purple_dim"
                        android:padding="12dp">

                        <TextView android:text="PRIME" android:textSize="7sp"
                            android:textColor="@color/accent_purple" android:letterSpacing="0.2"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvPrimeFreq" android:text="—"
                            android:textSize="18sp" android:textColor="@color/accent_purple"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="3dp"/>
                        <TextView android:id="@+id/tvPrimeGov" android:text="—"
                            android:textSize="9sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                        <TextView android:text="cpu7  ·  Prime" android:textSize="8sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── PİL + GPU ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- PİL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="22dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:text="PİL" android:textSize="7sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvBattery" android:text="—%"
                        android:textSize="34sp" android:textColor="@color/accent_green"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="2dp"/>

                    <TextView android:id="@+id/tvCharging" android:text="—"
                        android:textSize="10sp" android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"/>

                    <TextView android:id="@+id/tvBatTemp" android:text="—°C"
                        android:textSize="10sp" android:textColor="@color/accent_orange"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>

                    <TextView android:id="@+id/tvBatCurrent" android:text="— mA"
                        android:textSize="10sp" android:textColor="@color/accent_cyan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"/>

                    <TextView android:id="@+id/tvBatVoltage" android:text="— mV"
                        android:textSize="10sp" android:textColor="@color/text_secondary"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- GPU + RAM -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- GPU -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="5dp"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="22dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView android:text="GPU" android:textSize="7sp"
                            android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                        <TextView android:id="@+id/tvGpuFreq" android:text="—"
                            android:textSize="22sp" android:textColor="@color/accent_yellow"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="2dp"/>

                        <TextView android:text="Mali-G615 MC6" android:textSize="9sp"
                            android:textColor="@color/text_secondary" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- RAM -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_card"
                    app:cardCornerRadius="22dp"
                    app:strokeColor="@color/divider"
                    app:strokeWidth="1dp"
                    app:cardElevation="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView android:text="RAM" android:textSize="7sp"
                            android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                        <TextView android:id="@+id/tvRamUsed" android:text="—"
                            android:textSize="22sp" android:textColor="@color/accent_purple"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="2dp"/>

                        <TextView android:id="@+id/tvRamTotal" android:text="— GB toplam"
                            android:textSize="9sp" android:textColor="@color/text_secondary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>

        <!-- ── AKTİF PROFİL + EKRAN SÜRESİ ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp">

            <!-- Profil -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="22dp"
                app:strokeColor="@color/accent_cyan_dim"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:text="PROFİL" android:textSize="7sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvActiveProfile" android:text="—"
                        android:textSize="18sp" android:textColor="@color/accent_cyan"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="3dp"/>

                    <TextView android:id="@+id/tvAutoProfile" android:text="Manuel"
                        android:textSize="10sp" android:textColor="@color/accent_cyan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Ekran Süresi özeti -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_card"
                app:cardCornerRadius="22dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView android:text="EKRAN SÜRESİ" android:textSize="7sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>

                    <TextView android:id="@+id/tvHomeScreenOn" android:text="—"
                        android:textSize="18sp" android:textColor="@color/accent_green"
                        android:textStyle="bold" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:layout_marginTop="3dp"/>

                    <TextView android:id="@+id/tvHomeDeepSleep" android:text="💤 —"
                        android:textSize="10sp" android:textColor="@color/accent_cyan"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"/>

                    <TextView android:id="@+id/tvHomeScreenPeriod" android:text="—"
                        android:textSize="9sp" android:textColor="@color/text_hint"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- ── ÇEKİRDEKLER ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView android:text="ÇEKİRDEKLER" android:textSize="7sp"
                        android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"/>

                    <TextView android:id="@+id/tvCoreOnlineCount" android:text="8/8"
                        android:textSize="9sp" android:textColor="@color/accent_green"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/llCoreStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── CANLI FREKANS GRAFİĞİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView android:text="CANLI FREKANS"
                        android:textSize="7sp" android:textColor="@color/text_secondary"
                        android:letterSpacing="0.2" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"/>

                    <TextView android:id="@+id/tvChartStatus" android:text="● CANLI"
                        android:textSize="9sp" android:textColor="@color/accent_green"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <com.cpucontrol.FreqChartView
                    android:id="@+id/freqChart"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── SİSTEM BİLGİSİ ── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="22dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView android:text="SİSTEM" android:textSize="7sp"
                    android:textColor="@color/text_secondary" android:letterSpacing="0.2"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"/>

                <!-- Satır 1: Uptime + TCP -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Çalışma Süresi" android:textSize="9sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvSysUptime" android:text="—"
                            android:textSize="13sp" android:textColor="@color/text_primary"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="TCP Congestion" android:textSize="9sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvTcpCongestion" android:text="—"
                            android:textSize="13sp" android:textColor="@color/accent_cyan"
                            android:textStyle="bold" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Satır 2: Kernel + Android -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Kernel" android:textSize="9sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvKernelVer" android:text="—"
                            android:textSize="11sp" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">
                        <TextView android:text="Android" android:textSize="9sp"
                            android:textColor="@color/text_hint" android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>
                        <TextView android:id="@+id/tvAndroidVer" android:text="—"
                            android:textSize="11sp" android:textColor="@color/text_primary"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
