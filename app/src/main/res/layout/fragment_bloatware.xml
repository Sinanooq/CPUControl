<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Üst bar: arama + filtre -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="12dp"
        android:paddingBottom="6dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="14dp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"
            app:cardElevation="0dp">

            <EditText
                android:id="@+id/etBloatSearch"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="Uygulama ara..."
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:background="@null"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="13sp"
                android:inputType="text"
                android:singleLine="true"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- Filtre: Tümü / Sistem / Dondurulmuş -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterAll"
            android:text="Tümü"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            app:cornerRadius="12dp"
            android:backgroundTint="@color/accent_cyan"
            android:textColor="@color/on_primary"
            android:textSize="11sp"/>
    </LinearLayout>

    <!-- Filtre chip'leri -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterSystem"
            android:text="Sistem"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp"
            app:cornerRadius="10dp"
            android:backgroundTint="@color/bg_elevated"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            app:strokeColor="@color/divider"
            app:strokeWidth="1dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFilterDisabled"
            android:text="Dondurulmuş"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="6dp"
            app:cornerRadius="10dp"
            android:backgroundTint="@color/bg_elevated"
            android:textColor="@color/accent_orange"
            android:textSize="11sp"
            app:strokeColor="@color/accent_orange_dim"
            app:strokeWidth="1dp"/>

        <TextView
            android:id="@+id/tvBloatCount"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="end|center_vertical"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/text_hint"/>
    </LinearLayout>

    <!-- Uyarı -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="6dp"
        app:cardBackgroundColor="@color/accent_orange_dim"
        app:cardCornerRadius="12dp"
        app:strokeColor="@color/accent_orange"
        app:strokeWidth="1dp"
        app:cardElevation="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:text="⚠  Sistem uygulamalarını dondurmak bazı özellikleri bozabilir. Silmek yerine dondurma önerilir — geri alınabilir."
            android:textSize="10sp"
            android:textColor="@color/accent_orange"/>
    </com.google.android.material.card.MaterialCardView>

    <!-- Liste -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBloatware"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"/>

</LinearLayout>
